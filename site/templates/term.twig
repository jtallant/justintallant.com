{#
    List entries assigned to a particular Term
    -------------------------------
    Taxonomy = categories
    Term = Web Development

    Example:
    -------------------------------
    # <h1>Web Development</h1>
    #
    # <a href="#">Some Web Dev Post</a>
    # <a href="#">Some Web Dev Post</a>
    # <a href="#">Some Web Dev Post</a>
#}

{% extends 'layouts/master' %}

{% block title %}{{ term.name }}{% endblock %}

{% block content %}
    <h1 class="category-title">{{ term.name }}</h1>
    <div class="category-articles">
        {% for entry in term.entries %}
            {% include 'partials/article' %}
        {% endfor %}
    </div>
{% endblock content %}