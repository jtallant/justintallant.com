<!DOCTYPE html>
<html lang="en">
    <head>
        {% block head %}
            <meta charset="utf-8">
            <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
            <title>
                {% block title %}
                    {{ entry.seoTitle ?? skimpy.site.title }}
                {% endblock title %}
            </title>
            <link rel="stylesheet" type="text/css" href="/css/site.css" />
            <meta name="viewport" content="width=device-width, initial-scale=1.0">
            {% block metaDescription %}
            {% endblock metaDescription %}
            <meta name="author" content="{{ skimpy.site.author }}">
        {% endblock head %}
    </head>
    <body>
        <header id="site-header">
            {% block header %}
                <p id="site-title"><a href="{{ skimpy.url }}">{{ skimpy.site.title }}</a></p>
                <p id="site-tagline">{{ skimpy.site.tagline }}</p>
                <nav id="site-nav">
                    <a href="/pages/projects">Projects</a>
                    <a href="/categories/ideas-i-love">Ideas I love</a>
                </nav>
                <img id="site-image" src="/img/justin-and-lars.jpg" alt="Justin and Lars" />
            {% endblock header %}
        </header>
        <main>
            {% block content %}
            {% endblock content %}
        </main>
        <footer id="site-footer">
            {% block footer %}
            {% endblock footer %}
        </footer>
        {% block scripts %}
        {% endblock scripts %}
    </body>
</html>